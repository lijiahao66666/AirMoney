# AirMoney Server 环境变量示例
# 复制为 .env 并填写实际值

PORT=9002

# 腾讯云 API 密钥（用于 Hunyuan 等 API 签名）
TENCENT_SECRET_ID=AKID0sX4QZhiX9YkiU2NVQBk7IF4h7KK7g2A
TENCENT_SECRET_KEY=wfASWN0QhkaDdrrdCYhdMsAE5qOjrnW1

# 静态 API 密钥（可选，不设置则允许所有请求，开发模式）
API_KEY=af9a7d9ac145f539c84616012f9398b121cee1ad65005f3fc055f056aa4fd3fc

# 短信验证码（腾讯云 SMS）
# SMS_APP_ID: 短信控制台 → 应用管理 → SDK AppID
# SMS_SIGN: 签名管理中审核通过的签名内容
# SMS_TEMPLATE_ID: 正文模板管理中的模板 ID
# SMS_TEMPLATE_PARAM_COUNT: 1=仅{1}验证码，2={1}验证码+{2}分钟
SMS_APP_ID=1401090403
SMS_SIGN=杭州余杭艾养笙电子商务
SMS_TEMPLATE_ID=2605111
SMS_TEMPLATE_PARAM_COUNT=1
